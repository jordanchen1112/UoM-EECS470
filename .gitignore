# =========================================================
# Only track selected folders
# =========================================================

/*
!/.gitignore
!/test/
!/test/**
!/verilog/
!/verilog/**

# If your folder is actually named Test instead of test, use these:
# !/Test/
# !/Test/**


# =========================================================
# misc
# =========================================================

*.pdf


# =========================================================
# zip files
# =========================================================

*.zip
*.gz
*.tgz


# =========================================================
# verilog compilation
# =========================================================

*simv
*.daidir
*.key
*.vdb
vc_hdrs.h
debug_bin
csrc/
urgReport/
cov_report_*/


# =========================================================
# build / output folders
# =========================================================

build/

# Ignore output folders, but keep correct_out folders
output/*
!output/correct_out/
!output/correct_out/**

# If correct_out is directly under test/ or verilog/, this also keeps it
correct_out/
!correct_out/
!correct_out/**


# =========================================================
# synthesis files
# =========================================================

*.vg
*.rep
*.ddc
*.chk
*.log
*.syn
*.db
*.svf
*.mr
*.pvl
*_svsim.sv


# =========================================================
# verdi
# =========================================================

verdi*
novas*
*fsdb*


# =========================================================
# program memory compilation
# =========================================================

*.elf
*.mem
*.dump
*.dump_*


# =========================================================
# per-run output files
# =========================================================

*.out
*.cpi
*.wb
*.ppln
*.vcd